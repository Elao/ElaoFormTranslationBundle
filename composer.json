{
    "name": "elao/form-translation-bundle",
    "type": "symfony-bundle",
    "description": "Generate translation key for forms",
    "keywords": ["elao", "form", "translation"],
    "homepage": "https://github.com/Elao/ElaoFormTranslationBundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Elao",
            "homepage": "http://www.elao.com"
        },
        {
            "name": "Thomas Jarrand",
            "homepage": "https://github.com/Tom32i"
        }
    ],
    "require": {
        "php": "^8.2",
        "symfony/framework-bundle": "^6.4|^7.4|^8.0",
        "symfony/form": "^6.4|^7.4|^8.0",
        "symfony/property-access": "^6.4|^7.4|^8.0"
    },
    "require-dev": {
        "ekino/phpstan-banned-code": "^3.2",
        "friendsofphp/php-cs-fixer": "^3.10",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.2",
        "phpstan/phpstan-symfony": "^2.0",
        "symfony/phpunit-bridge": "^6.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Elao\\Bundle\\FormTranslationBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elao\\Bundle\\FormTranslationBundle\\Tests\\": "tests/"
        }
    },
    "prefer-stable": true,
    "minimum-stability": "dev",
    "extra": {
        "branch-alias": {
            "dev-master": "5.x-dev"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
